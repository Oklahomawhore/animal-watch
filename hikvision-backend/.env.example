# 海康互联开放平台配置
HIK_APP_KEY=your_app_key_here
HIK_APP_SECRET=your_app_secret_here
HIK_BASE_URL=https://open-api.hikiot.com

# 事件订阅加密配置（从海康平台获取）
HIK_ENCRYPT_KEY=your_encrypt_key_here
HIK_VERIFICATION_TOKEN=your_verification_token_here

# 数据库配置
DATABASE_URL=sqlite:///hikvision.db
# 或使用 MySQL
# DATABASE_URL=mysql+pymysql://user:password@localhost/hikvision

# Redis配置
REDIS_URL=redis://localhost:6379/0

# Flask配置
SECRET_KEY=your-secret-key-here-change-in-production
FLASK_DEBUG=False
PORT=5000
