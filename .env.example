# 林麝健康监测系统环境变量配置

# ==========================================
# 数据库配置
# ==========================================
MYSQL_ROOT_PASSWORD=your_secure_root_password
MYSQL_PASSWORD=your_secure_mysql_password

# ==========================================
# InfluxDB 配置
# ==========================================
INFLUX_USER=admin
INFLUX_PASSWORD=your_secure_influx_password
INFLUX_TOKEN=your_secure_influx_token

# ==========================================
# JWT 密钥
# ==========================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ==========================================
# 微信小程序配置 (可选)
# ==========================================
WX_APP_ID=your_wechat_app_id
WX_APP_SECRET=your_wechat_app_secret

# ==========================================
# 海康摄像头默认配置 (可选)
# ==========================================
HIKVISION_DEFAULT_USERNAME=admin
HIKVISION_DEFAULT_PASSWORD=your_default_camera_password

# ==========================================
# 告警通知配置 (可选)
# ==========================================
# 企业微信
WECHAT_WORK_CORP_ID=your_corp_id
WECHAT_WORK_AGENT_ID=your_agent_id
WECHAT_WORK_SECRET=your_secret

# 短信通知 (阿里云)
ALIYUN_SMS_ACCESS_KEY=your_access_key
ALIYUN_SMS_SECRET=your_secret
ALIYUN_SMS_SIGN_NAME=your_sign_name
