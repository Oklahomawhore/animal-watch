/* pages/animal-detail/animal-detail.wxss */
.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 40rpx;
}

/* 加载状态 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #E0E0E0;
  border-top-color: #4CAF50;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 页面头部 */
.page-header {
  background: linear-gradient(135deg, #2E7D32 0%, #4CAF50 100%);
  padding: 40rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #fff;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
}

.back-btn .icon {
  font-size: 32rpx;
  font-weight: bold;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
}

.placeholder {
  width: 60rpx;
}

/* 动物头部信息 */
.animal-header {
  margin: -30rpx 30rpx 30rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.animal-avatar {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  overflow: hidden;
  background: #F0F0F0;
}

.animal-avatar image {
  width: 100%;
  height: 100%;
}

.health-badge {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  color: #fff;
  white-space: nowrap;
}

.health-badge.healthy { background: #4CAF50; }
.health-badge.warning { background: #FF9800; }
.health-badge.danger { background: #F44336; }

.animal-basic-info {
  flex: 1;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.name-row .name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.name-row .gender {
  font-size: 24rpx;
  color: #666;
  background: #F0F0F0;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.meta-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.meta-row .ear-tag {
  font-size: 24rpx;
  color: #999;
}

.meta-row .divider {
  color: #DDD;
}

.meta-row .age {
  font-size: 24rpx;
  color: #666;
}

.shed-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #666;
}

/* 数据看板 */
.dashboard-section {
  margin: 0 30rpx 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.dashboard-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.dashboard-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.card-header .icon {
  font-size: 32rpx;
}

.card-header .label {
  font-size: 26rpx;
  color: #666;
}

.card-body {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.card-body .value {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}

.card-body .unit {
  font-size: 24rpx;
  color: #999;
}

.card-footer .status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  display: inline-block;
}

.status.good {
  background: #E8F5E9;
  color: #2E7D32;
}

.status.normal {
  background: #FFF8E1;
  color: #F57C00;
}

.status.warning {
  background: #FFEBEE;
  color: #C62828;
}

/* 图表区域 */
.chart-section {
  margin: 0 30rpx 30rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-header .section-title {
  margin-bottom: 0;
}

.section-header .more {
  font-size: 26rpx;
  color: #4CAF50;
}

.time-range-tabs {
  display: flex;
  background: #F0F0F0;
  border-radius: 8rpx;
  padding: 4rpx;
}

.time-range-tabs .tab {
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  color: #666;
  border-radius: 6rpx;
  transition: all 0.3s;
}

.time-range-tabs .tab.active {
  background: #fff;
  color: #4CAF50;
  font-weight: bold;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.chart-container {
  width: 100%;
  height: 400rpx;
}

/* 标签页 */
.tab-bar {
  margin: 0 30rpx 20rpx;
  background: #fff;
  border-radius: 16rpx;
  display: flex;
  padding: 8rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 12rpx;
  position: relative;
  transition: all 0.3s;
}

.tab-item.active {
  background: #E8F5E9;
  color: #2E7D32;
  font-weight: bold;
}

.tab-item .badge {
  position: absolute;
  top: 10rpx;
  right: 20rpx;
  background: #F44336;
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
}

/* 标签页内容 */
.tab-content {
  margin: 0 30rpx;
}

.section {
  margin-bottom: 30rpx;
}

/* 诊疗记录摘要 */
.medical-summary-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.medical-summary-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  border-left: 8rpx solid #4CAF50;
}

.medical-summary-item.warning {
  border-left-color: #FF9800;
}

.summary-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.summary-header .diagnosis {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.summary-header .status-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status-tag.active {
  background: #E8F5E9;
  color: #2E7D32;
}

.status-tag.completed {
  background: #E3F2FD;
  color: #1565C0;
}

.medicine-preview {
  font-size: 24rpx;
  color: #666;
}

/* 饲养预览 */
.feeding-preview {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-around;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.preview-item {
  text-align: center;
}

.preview-item .label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.preview-item .value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.preview-item .value.completed {
  color: #4CAF50;
}

.preview-item .value.pending {
  color: #FF9800;
}

/* 诊疗记录列表 */
.medical-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.medical-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.medical-card .card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.diagnosis-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.diagnosis-title .icon {
  font-size: 36rpx;
}

.diagnosis-title .text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.status-badge {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.status-badge.active {
  background: #E8F5E9;
  color: #2E7D32;
}

.status-badge.completed {
  background: #E3F2FD;
  color: #1565C0;
}

.medicine-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.medicine-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #F8F9FA;
  padding: 20rpx;
  border-radius: 12rpx;
}

.med-icon {
  font-size: 32rpx;
}

.med-info {
  flex: 1;
}

.med-info .name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.med-info .dosage {
  font-size: 24rpx;
  color: #666;
  margin-top: 4rpx;
  display: block;
}

.medical-card .card-footer {
  display: flex;
  gap: 40rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F0F0;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.info-item .label {
  font-size: 24rpx;
  color: #999;
}

.info-item .value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.info-item .value.urgent {
  color: #F44336;
}

.notes {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #FFF8E1;
  border-radius: 12rpx;
}

.notes .label {
  font-size: 24rpx;
  color: #F57C00;
  margin-right: 8rpx;
}

.notes .text {
  font-size: 24rpx;
  color: #666;
}

/* 饲养记录列表 */
.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #DDD;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.checkbox.checked {
  background: #4CAF50;
  border-color: #4CAF50;
  color: #fff;
  font-size: 24rpx;
}

.checkbox.disabled {
  border-color: #EEE;
  color: #CCC;
}

.record-content {
  flex: 1;
}

.record-content .text {
  font-size: 30rpx;
  color: #333;
  display: block;
}

.record-content .meta {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.record-item.completed .record-content .text {
  color: #999;
  text-decoration: line-through;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 60rpx;
}

.empty-state .icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-state .text {
  font-size: 32rpx;
  color: #666;
}

/* 悬浮按钮 */
.fab-button {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #2E7D32 0%, #4CAF50 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(76, 175, 80, 0.4);
  z-index: 100;
}

.fab-button .icon {
  font-size: 48rpx;
  color: #fff;
  font-weight: bold;
}

.bottom-spacer {
  height: 160rpx;
}
