<!-- pages/monitor/monitor.wxml -->
<view class="container">
  <!-- 圈舍选择器 -->
  <view class="shed-selector">
    <view class="selector-item {{currentShed === 'all' ? 'active' : ''}}" bindtap="selectShed" data-id="all">
      全部
    </view>
    <view 
      class="selector-item {{currentShed === item.id ? 'active' : ''}}" 
      wx:for="{{shedList}}" 
      wx:key="id"
      bindtap="selectShed"
      data-id="{{item.id}}"
    >
      {{item.name}}
    </view>
  </view>

  <!-- 摄像头网格 -->
  <view class="camera-grid">
    <view 
      class="camera-card {{item.status}}" 
      wx:for="{{cameraList}}" 
      wx:key="id"
      bindtap="openCameraDetail"
      data-id="{{item.id}}"
    >
      <view class="camera-preview">
        <image 
          wx:if="{{item.snapshotUrl}}" 
          src="{{item.snapshotUrl}}" 
          mode="aspectFill"
          class="snapshot"
        />
        <view wx:else class="camera-placeholder">📹</view>
        <view class="live-badge" wx:if="{{item.status === 'online'}}">● LIVE</view>
      </view>
      <view class="camera-info">
        <text class="name">{{item.name}}</text>
        <view class="meta">
          <text class="status-badge {{item.status}}">{{item.statusText}}</text>
          <text class="count" wx:if="{{item.animalCount}}">{{item.animalCount}}只</text>
        </view>
        <view class="alert-text" wx:if="{{item.alertType}}">
          ⚠️ {{item.alertType}}
        </view>
      </view>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="action-bar">
    <view class="action-btn" bindtap="takeSnapshot">
      <text class="icon">📷</text>
      <text>截图</text>
    </view>
    <view class="action-btn" bindtap="startRecord">
      <text class="icon">🎥</text>
      <text>录像</text>
    </view>
    <view class="action-btn" bindtap="openIntercom">
      <text class="icon">🎤</text>
      <text>对讲</text>
    </view>
    <view class="action-btn" bindtap="openSettings">
      <text class="icon">⚙️</text>
      <text>设置</text>
    </view>
  </view>
</view>
