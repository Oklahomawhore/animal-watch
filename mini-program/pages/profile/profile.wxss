/* pages/profile/profile.wxss */
.container {
  min-height: 100vh;
  background: #F5F5F5;
}

/* 用户信息卡 */
.user-card {
  background: linear-gradient(135deg, #2E7D32 0%, #1B5E20 100%);
  padding: 60rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
}

.user-info .name {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.user-info .meta {
  display: flex;
  gap: 24rpx;
}

.user-info .role {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  background: rgba(255, 255, 255, 0.2);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.user-info .location {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 数据统计 */
.stats-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin: -30rpx 40rpx 40rpx;
  padding: 40rpx;
  display: flex;
  justify-content: space-around;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.stat-item {
  text-align: center;
}

.stat-item .value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #2E7D32;
  margin-bottom: 8rpx;
}

.stat-item .label {
  font-size: 24rpx;
  color: #757575;
}

/* 功能菜单 */
.menu-list {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin: 0 40rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item .icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 24rpx;
}

.menu-item .name {
  flex: 1;
  font-size: 32rpx;
  color: #212121;
}

.menu-item .badge {
  background: #FF6B35;
  color: #FFFFFF;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 16rpx;
}

.menu-item .arrow {
  font-size: 40rpx;
  color: #BDBDBD;
}

/* 退出登录 */
.logout-btn {
  margin: 60rpx 40rpx;
  padding: 32rpx;
  text-align: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  font-size: 32rpx;
  color: #F44336;
}
