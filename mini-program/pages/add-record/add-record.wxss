/* pages/add-record/add-record.wxss */
.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 30rpx;
  padding-bottom: 160rpx;
}

/* 区块标题 */
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-header .section-title {
  margin-bottom: 0;
}

/* 记录类型选择 */
.type-section {
  margin-bottom: 30rpx;
}

.type-list {
  display: flex;
  gap: 20rpx;
}

.type-item {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.type-item.active {
  border-color: #4CAF50;
  background: #E8F5E9;
}

.type-item .icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 12rpx;
}

.type-item .label {
  font-size: 28rpx;
  color: #666;
}

.type-item.active .label {
  color: #2E7D32;
  font-weight: bold;
}

/* 动物选择 */
.animal-section {
  margin-bottom: 30rpx;
}

.selected-count {
  font-size: 26rpx;
  color: #4CAF50;
}

.animal-selector {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
}

.selector-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.selector-content .placeholder {
  font-size: 28rpx;
  color: #999;
}

.selector-content .arrow,
.selected-list .arrow {
  font-size: 32rpx;
  color: #CCC;
}

.selected-list {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
}

.selected-tag {
  background: #E8F5E9;
  color: #2E7D32;
  font-size: 26rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

/* 日期显示 */
.date-section {
  margin-bottom: 30rpx;
}

.date-display {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  font-size: 30rpx;
  color: #333;
}

/* 内容输入 */
.content-section {
  margin-bottom: 30rpx;
}

.content-input {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  width: 100%;
  min-height: 240rpx;
  font-size: 30rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 图片上传 */
.image-section {
  margin-bottom: 30rpx;
}

.image-section .count {
  font-size: 26rpx;
  color: #999;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.add-image {
  width: 200rpx;
  height: 200rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 2rpx dashed #DDD;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-image .icon {
  font-size: 48rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.add-image .label {
  font-size: 24rpx;
  color: #999;
}

/* 语音录制 */
.voice-section {
  margin-bottom: 30rpx;
}

.voice-recorder {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  text-align: center;
}

.record-btn {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 30rpx 60rpx;
  background: #F5F5F5;
  border-radius: 100rpx;
  transition: all 0.3s;
}

.record-btn.recording {
  background: #FFEBEE;
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.record-btn .icon {
  font-size: 48rpx;
}

.record-btn .label {
  font-size: 28rpx;
  color: #666;
}

.record-btn.recording .label {
  color: #F44336;
}

.record-hint {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #F44336;
}

.voice-player {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.voice-wave {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 80rpx;
  margin-bottom: 20rpx;
}

.wave-bar {
  width: 8rpx;
  background: #4CAF50;
  border-radius: 4rpx;
  animation: wave 1s ease-in-out infinite;
}

.wave-bar:nth-child(2) { animation-delay: 0.1s; }
.wave-bar:nth-child(3) { animation-delay: 0.2s; }
.wave-bar:nth-child(4) { animation-delay: 0.3s; }
.wave-bar:nth-child(5) { animation-delay: 0.4s; }
.wave-bar:nth-child(6) { animation-delay: 0.5s; }
.wave-bar:nth-child(7) { animation-delay: 0.6s; }
.wave-bar:nth-child(8) { animation-delay: 0.7s; }

@keyframes wave {
  0%, 100% { transform: scaleY(0.5); }
  50% { transform: scaleY(1); }
}

.voice-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.voice-info .duration {
  font-size: 28rpx;
  color: #666;
}

.actions {
  display: flex;
  gap: 30rpx;
}

.action-btn {
  font-size: 26rpx;
  color: #4CAF50;
}

.action-btn.delete {
  color: #F44336;
}

/* 底部按钮 */
.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 32rpx;
  border: none;
  margin: 0;
  padding: 0;
}

.btn.cancel {
  background: #F5F5F5;
  color: #666;
}

.btn.submit {
  background: linear-gradient(135deg, #2E7D32 0%, #4CAF50 100%);
  color: #fff;
}

.btn.submit.loading {
  opacity: 0.7;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 100%;
  background: #fff;
  border-radius: 40rpx 40rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s;
}

.modal.show .modal-content {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.modal-header .title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-header .close {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
}

.animal-list {
  flex: 1;
  max-height: 600rpx;
}

.animal-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.animal-item.selected {
  background: #E8F5E9;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #DDD;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  color: #fff;
}

.animal-item.selected .checkbox {
  background: #4CAF50;
  border-color: #4CAF50;
}

.animal-info {
  flex: 1;
}

.animal-info .name {
  font-size: 30rpx;
  color: #333;
  display: block;
}

.animal-info .ear-tag {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

.modal-footer {
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #F0F0F0;
}

.modal-footer .btn.confirm {
  width: 100%;
  background: linear-gradient(135deg, #2E7D32 0%, #4CAF50 100%);
  color: #fff;
}
